        "# --- Softmax baseline: a plain classifier head, no metric learning ---\n",
        "class SoftmaxLoss(nn.Module):\n",
        "    def __init__(self, embed_dim, n_classes):\n",
        "        super().__init__()\n",
        "        self.fc = nn.Linear(embed_dim, n_classes)\n",
        "\n",
        "    def forward(self, embeddings, labels):\n",
        "        logits = self.fc(embeddings)\n",
        "        return F.cross_entropy(logits, labels)\n",
        "\n",
        "def train_model_v2(loss_name, epochs, backbone, lr=1e-4):\n",
        "    model = EmbeddingNet(backbone=backbone).to(DEVICE)\n",
        "    if loss_name == \"triplet\":\n",
        "        criterion = BatchHardTripletLoss(margin=0.3)\n",
        "        params = model.parameters()\n",
        "    elif loss_name == \"arcface\":\n",
        "        criterion = ArcFaceLoss(EMBED_DIM, n_classes=len(train_ids)).to(DEVICE)\n",
        "        params = list(model.parameters()) + list(criterion.parameters())\n",
        "    elif loss_name == \"softmax\":\n",
        "        criterion = SoftmaxLoss(EMBED_DIM, n_classes=len(train_ids)).to(DEVICE)\n",
        "        params = list(model.parameters()) + list(criterion.parameters())\n",
        "    else:\n",
        "        raise ValueError(loss_name)\n",
        "\n",
        "    optimizer = torch.optim.Adam(params, lr=lr)\n",
        "    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)\n",
        "\n",
        "    for epoch in range(epochs):\n",
        "        model.train()\n",
        "        epoch_loss = 0.0\n",
        "        for imgs, labels in train_loader:\n",
        "            imgs, labels = imgs.to(DEVICE), labels.to(DEVICE)\n",
        "            embeddings = model(imgs)\n",
        "            loss = criterion(embeddings, labels)\n",
        "            optimizer.zero_grad()\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "            epoch_loss += loss.item()\n",
        "        scheduler.step()\n",
        "        avg_loss = epoch_loss / max(1, len(train_loader))\n",
        "        print(f\"[{loss_name}/{backbone}] epoch {epoch+1}/{epochs} - loss {avg_loss:.4f}\")\n",
        "    return model\n",
        "\n",
        "# Run the 3 additional configs — 25 epochs each to keep total runtime reasonable\n",
        "ABLATION_EPOCHS = 25\n",
        "\n",
        "model_softmax_r50 = train_model_v2(\"softmax\", ABLATION_EPOCHS, \"resnet50\")\n",
        "model_triplet_eff = train_model_v2(\"triplet\", ABLATION_EPOCHS, \"efficientnet_b0\")\n",
        "model_arcface_eff = train_model_v2(\"arcface\", ABLATION_EPOCHS, \"efficientnet_b0\")\n",
        "\n",
        "# Evaluate all 5 models together\n",
        "all_models = {\n",
        "    \"Triplet (ResNet50)\": model_triplet,\n",
        "    \"ArcFace (ResNet50)\": model_arcface,\n",
        "    \"Softmax (ResNet50)\": model_softmax_r50,\n",
        "    \"Triplet (EfficientNet-B0)\": model_triplet_eff,\n",
        "    \"ArcFace (EfficientNet-B0)\": model_arcface_eff,\n",
        "}\n",
        "\n",
        "full_results = {}\n",
        "for name, model in all_models.items():\n",
        "    emb, lab, _ = embed_dataset(model, DATA_DIR, test_ids, eval_transform)\n",
        "    g_idx, q_idx = gallery_query_split(lab, gallery_per_id=1)\n",
        "    rank_acc, mAP = compute_rank_map(emb, lab, g_idx, q_idx)\n",
        "    full_results[name] = {**{f\"Rank-{r}\": v for r, v in rank_acc.items()}, \"mAP\": mAP}\n",
        "    print(f\"{name}: {full_results[name]}\")\n",
        "\n",
        "full_results_df = pd.DataFrame(full_results).T.sort_values(\"mAP\", ascending=False)\n",
        "print(full_results_df)"
