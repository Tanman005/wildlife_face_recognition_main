      "source": [
        "import os\n",
        "import random\n",
        "import glob\n",
        "import numpy as np\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.nn.functional as F\n",
        "from torch.utils.data import Dataset, DataLoader, Sampler\n",
        "from torchvision import transforms, models\n",
        "from PIL import Image, ImageDraw\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.manifold import TSNE\n",
        "\n",
        "SEED = 42\n",
        "random.seed(SEED)\n",
        "np.random.seed(SEED)\n",
        "torch.manual_seed(SEED)\n",
        "\n",
        "DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "print(\"Using device:\", DEVICE)\n",
        "\n",
        "DATA_DIR = \"/content/data_formatted\"   # <-- your real ATRW re-id data, already reshaped\n",
        "EMBED_DIM = 512\n",
        "IMG_SIZE = 224              # full size — you're on a Colab GPU now\n",
        "torch.set_num_threads(os.cpu_count() or 4)\n",
        "\n",
        "def split_by_identity(root, test_frac=0.25):\n",
        "    \"\"\"Split identities (not images) into train / test-gallery+query sets.\"\"\"\n",
        "    ids = sorted(os.listdir(root))\n",
        "    random.shuffle(ids)\n",
        "    n_test = max(1, int(len(ids) * test_frac))\n",
        "    test_ids, train_ids = ids[:n_test], ids[n_test:]\n",
        "    return train_ids, test_ids\n",
        "\n",
        "train_ids, test_ids = split_by_identity(DATA_DIR)\n",
        "print(f\"Train identities: {len(train_ids)} | Held-out test identities: {len(test_ids)}\")\n",
        "\n",
        "def align_face(pil_img):\n",
        "    # TODO: replace with real detection + keypoint-based alignment for actual data.\n",
        "    return pil_img\n",
        "\n",
        "train_transform = transforms.Compose([\n",
        "    transforms.Lambda(align_face),\n",
        "    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n",
        "    transforms.ColorJitter(brightness=0.3, contrast=0.3, saturation=0.2),\n",
        "    transforms.RandomRotation(10),\n",
        "    transforms.GaussianBlur(kernel_size=3, sigma=(0.1, 1.5)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),\n",
        "])\n",
        "\n",
        "eval_transform = transforms.Compose([\n",
        "    transforms.Lambda(align_face),\n",
        "    transforms.Resize((IMG_SIZE, IMG_SIZE)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]),\n",
        "])\n",
        "\n",
        "class ReIDDataset(Dataset):\n",
        "    def __init__(self, root, identity_list, transform):\n",
        "        self.samples = []\n",
        "        self.transform = transform\n",
        "        self.label_to_idx = {iid: i for i, iid in enumerate(identity_list)}\n",
        "        for iid in identity_list:\n",
        "            for fp in glob.glob(os.path.join(root, iid, \"*.jpg\")):\n",
        "                self.samples.append((fp, self.label_to_idx[iid]))\n",
        "        self.labels = np.array([s[1] for s in self.samples])\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.samples)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        fp, label = self.samples[idx]\n",
        "        img = Image.open(fp).convert(\"RGB\")\n",
        "        img = self.transform(img)\n",
        "        return img, label\n",
        "\n",
        "class PKSampler(Sampler):\n",
        "    def __init__(self, labels, P=8, K=4):\n",
        "        self.labels = np.array(labels)\n",
        "        self.P, self.K = P, K\n",
        "        self.unique_labels = np.unique(labels)\n",
        "\n",
        "    def __iter__(self):\n",
        "        labels_pool = list(self.unique_labels)\n",
        "        random.shuffle(labels_pool)\n",
        "        for i in range(0, len(labels_pool), self.P):\n",
        "            batch_ids = labels_pool[i:i + self.P]\n",
        "            batch = []\n",
        "            for lid in batch_ids:\n",
        "                idxs = np.where(self.labels == lid)[0]\n",
        "                chosen = np.random.choice(idxs, size=self.K, replace=len(idxs) < self.K)\n",
        "                batch.extend(chosen.tolist())\n",
        "            yield batch\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.unique_labels) // self.P\n",
        "\n",
        "train_dataset = ReIDDataset(DATA_DIR, train_ids, train_transform)\n",
        "_P, _K = 8, 4\n",
        "train_sampler = PKSampler(train_dataset.labels, P=min(_P, len(train_ids)), K=_K)\n",
        "train_loader = DataLoader(train_dataset, batch_sampler=train_sampler)\n",
        "print(f\"Training images: {len(train_dataset)} across {len(train_ids)} identities\")\n",
        "\n",
        "class EmbeddingNet(nn.Module):\n",
        "    def __init__(self, embed_dim=EMBED_DIM, backbone=\"resnet50\"):\n",
        "        super().__init__()\n",
        "        if backbone == \"resnet50\":\n",
        "            base = models.resnet50(weights=models.ResNet50_Weights.IMAGENET1K_V2)\n",
        "            feat_dim = base.fc.in_features\n",
        "            base.fc = nn.Identity()\n",
        "        elif backbone == \"efficientnet_b0\":\n",
        "            base = models.efficientnet_b0(weights=models.EfficientNet_B0_Weights.IMAGENET1K_V1)\n",
        "            feat_dim = base.classifier[1].in_features\n",
        "            base.classifier = nn.Identity()\n",
        "        else:\n",
        "            raise ValueError(backbone)\n",
        "        self.backbone = base\n",
        "        self.fc = nn.Linear(feat_dim, embed_dim)\n",
        "\n",
        "    def forward(self, x):\n",
        "        feats = self.backbone(x)\n",
        "        emb = self.fc(feats)\n",
        "        return F.normalize(emb, p=2, dim=1)\n",
        "\n",
        "class BatchHardTripletLoss(nn.Module):\n",
        "    def __init__(self, margin=0.3):\n",
        "        super().__init__()\n",
        "        self.margin = margin\n",
        "\n",
        "    def forward(self, embeddings, labels):\n",
        "        pdist = torch.cdist(embeddings, embeddings, p=2)\n",
        "        labels = labels.unsqueeze(1)\n",
        "        same_id = labels == labels.t()\n",
        "        hardest_pos = (pdist * same_id.float()).max(dim=1)[0]\n",
        "        max_dist = pdist.max()\n",
        "        masked_neg = pdist + max_dist * same_id.float()\n",
        "        hardest_neg = masked_neg.min(dim=1)[0]\n",
        "        loss = F.relu(hardest_pos - hardest_neg + self.margin)\n",
        "        return loss.mean()\n",
        "\n",
        "class ArcFaceLoss(nn.Module):\n",
        "    def __init__(self, embed_dim, n_classes, s=30.0, m=0.5):\n",
        "        super().__init__()\n",
        "        self.weight = nn.Parameter(torch.randn(n_classes, embed_dim))\n",
        "        nn.init.xavier_uniform_(self.weight)\n",
        "        self.s, self.m = s, m\n",
        "\n",
        "    def forward(self, embeddings, labels):\n",
        "        W = F.normalize(self.weight, dim=1)\n",
        "        cos_theta = F.linear(embeddings, W).clamp(-1 + 1e-7, 1 - 1e-7)\n",
        "        theta = torch.acos(cos_theta)\n",
        "        target_logit = torch.cos(theta + self.m)\n",
        "        one_hot = F.one_hot(labels, num_classes=W.size(0)).float()\n",
        "        logits = (one_hot * target_logit + (1 - one_hot) * cos_theta) * self.s\n",
        "        return F.cross_entropy(logits, labels)\n",
        "\n",
        "DEMO_BACKBONE = \"resnet50\"\n",
        "DEMO_EPOCHS = 30\n",
        "\n",
        "def train_model(loss_name, epochs=5, backbone=\"resnet50\", lr=1e-4):\n",
        "    model = EmbeddingNet(backbone=backbone).to(DEVICE)\n",
        "    if loss_name == \"triplet\":\n",
        "        criterion = BatchHardTripletLoss(margin=0.3)\n",
        "        params = model.parameters()\n",
        "    elif loss_name == \"arcface\":\n",
        "        criterion = ArcFaceLoss(EMBED_DIM, n_classes=len(train_ids)).to(DEVICE)\n",
        "        params = list(model.parameters()) + list(criterion.parameters())\n",
        "    else:\n",
        "        raise ValueError(loss_name)\n",
        "\n",
        "    optimizer = torch.optim.Adam(params, lr=lr)\n",
        "    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=epochs)\n",
        "\n",
        "    history = []\n",
        "    for epoch in range(epochs):\n",
        "        model.train()\n",
        "        epoch_loss = 0.0\n",
        "        for imgs, labels in train_loader:\n",
        "            imgs, labels = imgs.to(DEVICE), labels.to(DEVICE)\n",
        "            embeddings = model(imgs)\n",
        "            loss = criterion(embeddings, labels)\n",
        "            optimizer.zero_grad()\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "            epoch_loss += loss.item()\n",
        "        scheduler.step()\n",
        "        avg_loss = epoch_loss / max(1, len(train_loader))\n",
        "        history.append(avg_loss)\n",
        "        print(f\"[{loss_name}/{backbone}] epoch {epoch+1}/{epochs} - loss {avg_loss:.4f}\")\n",
        "    return model, history\n",
        "\n",
        "model_triplet, hist_triplet = train_model(\"triplet\", epochs=DEMO_EPOCHS, backbone=DEMO_BACKBONE)\n",
        "model_arcface, hist_arcface = train_model(\"arcface\", epochs=DEMO_EPOCHS, backbone=DEMO_BACKBONE)\n",
        "\n",
        "@torch.no_grad()\n",
        "def embed_dataset(model, root, identity_list, transform):\n",
        "    model.eval()\n",
        "    ds = ReIDDataset(root, identity_list, transform)\n",
        "    loader = DataLoader(ds, batch_size=32, shuffle=False)\n",
        "    all_emb, all_labels = [], []\n",
        "    for imgs, labels in loader:\n",
        "        emb = model(imgs.to(DEVICE)).cpu()\n",
        "        all_emb.append(emb)\n",
        "        all_labels.append(labels)\n",
        "    return torch.cat(all_emb), torch.cat(all_labels), ds\n",
        "\n",
        "def gallery_query_split(labels, gallery_per_id=1, seed=SEED):\n",
        "    rng = np.random.RandomState(seed)\n",
        "    gallery_idx, query_idx = [], []\n",
        "    for lid in np.unique(labels):\n",
        "        idxs = np.where(labels.numpy() == lid)[0]\n",
        "        rng.shuffle(idxs)\n",
        "        gallery_idx.extend(idxs[:gallery_per_id])\n",
        "        query_idx.extend(idxs[gallery_per_id:])\n",
        "    return np.array(gallery_idx), np.array(query_idx)\n",
        "\n",
        "def compute_rank_map(embeddings, labels, gallery_idx, query_idx, ranks=(1, 5)):\n",
        "    g_emb, g_lab = embeddings[gallery_idx], labels[gallery_idx]\n",
        "    q_emb, q_lab = embeddings[query_idx], labels[query_idx]\n",
        "    dists = torch.cdist(q_emb, g_emb, p=2)\n",
        "    order = dists.argsort(dim=1)\n",
        "    rank_hits = {r: 0 for r in ranks}\n",
        "    average_precisions = []\n",
        "    for i in range(len(q_lab)):\n",
        "        ranked_labels = g_lab[order[i]]\n",
        "        matches = (ranked_labels == q_lab[i]).numpy().astype(int)\n",
        "        for r in ranks:\n",
        "            if matches[:r].sum() > 0:\n",
        "                rank_hits[r] += 1\n",
        "        if matches.sum() > 0:\n",
        "            precisions = np.cumsum(matches) / (np.arange(len(matches)) + 1)\n",
        "            average_precisions.append((precisions * matches).sum() / matches.sum())\n",
        "        else:\n",
        "            average_precisions.append(0.0)\n",
        "    rank_acc = {r: rank_hits[r] / len(q_lab) for r in ranks}\n",
        "    mAP = float(np.mean(average_precisions))\n",
        "    return rank_acc, mAP\n",
        "\n",
        "results_table = {}\n",
        "for name, model in [(f\"Triplet ({DEMO_BACKBONE})\", model_triplet), (f\"ArcFace ({DEMO_BACKBONE})\", model_arcface)]:\n",
        "    emb, lab, _ = embed_dataset(model, DATA_DIR, test_ids, eval_transform)\n",
        "    g_idx, q_idx = gallery_query_split(lab, gallery_per_id=1)\n",
        "    rank_acc, mAP = compute_rank_map(emb, lab, g_idx, q_idx)\n",
        "    results_table[name] = {**{f\"Rank-{r}\": v for r, v in rank_acc.items()}, \"mAP\": mAP}\n",
        "    print(f\"{name}: {results_table[name]}\")\n",
        "\n",
        "def plot_tsne(model, title):\n",
        "    emb, lab, _ = embed_dataset(model, DATA_DIR, test_ids, eval_transform)\n",
        "    proj = TSNE(n_components=2, random_state=SEED, perplexity=min(15, len(emb) - 1)).fit_transform(emb.numpy())\n",
        "    plt.figure(figsize=(6, 6))\n",
        "    plt.scatter(proj[:, 0], proj[:, 1], c=lab.numpy(), cmap=\"tab20\", s=40)\n",
        "    plt.title(title)\n",
        "    plt.xlabel(\"t-SNE dim 1\"); plt.ylabel(\"t-SNE dim 2\")\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(f\"/content/{title.replace(' ', '_')}_tsne.png\", dpi=150)\n",
        "    plt.show()\n",
        "\n",
        "plot_tsne(model_triplet, f\"Triplet_{DEMO_BACKBONE}_heldout\")\n",
        "plot_tsne(model_arcface, f\"ArcFace_{DEMO_BACKBONE}_heldout\")\n",
        "\n",
        "import pandas as pd\n",
        "results_df = pd.DataFrame(results_table).T\n",
        "print(results_df)"
